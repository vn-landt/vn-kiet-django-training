#application: ai-app-489908
#version: 1
runtime: python27
api_version: 1
threadsafe: yes

handlers:
- url: /static
  static_dir: static
- url: /media
  static_dir: media
- url: /.*
  script: main.application

libraries:
- name: django
  version: "1.11"
- name: PIL
  version: "1.1.7"

env_variables:
  DJANGO_SETTINGS_MODULE: "img2xl_project.settings"
  GEMINI_API_KEY: "YOUR_API_KEY_HERE"


skip_files:
- ^(.*/)?#.*#$
- ^(.*/)?.*~$
- ^(.*/)?.*\.py[co]$
- ^(.*/)?.*/RCS/.*$
- ^(.*/)?\..*$
- ^\.idea/.*$

